{
    "name": "hookbridge/hookbridge-php",
    "description": "Official PHP SDK for HookBridge - Webhook Delivery & Retry Service",
    "type": "library",
    "license": "MIT",
    "keywords": ["hookbridge", "webhooks", "sdk", "api"],
    "homepage": "https://hookbridge.io",
    "authors": [
        {
            "name": "HookBridge",
            "email": "support@hookbridge.io"
        }
    ],
    "require": {
        "php": ">=8.1",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "HookBridge\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "HookBridge\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "config": {
        "sort-packages": true
    }
}
